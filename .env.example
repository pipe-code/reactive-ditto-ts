# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real keys.
#
# SCOPE: .env is read ONLY by webpack (dotenv) at build time, for values you
# explicitly expose via DefinePlugin in webpack.config.js. PHP does NOT read
# this file.
#
# PHP-side configuration (e.g. the form proxy target for
# POST /wp-json/proxy/v1/submission) is a PHP constant — define it in
# wp-config.php instead:
#
#   define( 'PROXY_SUBMISSION_URL', 'https://api.example.com/submit' );
#
# Leave it undefined to disable the proxy endpoint.
